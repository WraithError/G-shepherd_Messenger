# Copy this to .env and fill in your values. If you cannot ask Claude or GPT for help to filling them.

# ⚠️ NEVER commit .env to git, unless repository is private!

APP_NAME=G-Shepherd
DEBUG=True

DATABASE_URL=postgresql://postgres:password@localhost:5432/gshepherd

REDIS_URL=redis://localhost:6379

SECRET_KEY=change-this-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
